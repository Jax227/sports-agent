# ── Literature Search ──────────────────────────────────────────
# Email for PubMed/Entrez (REQUIRED for PubMed connector)
ENTREZ_EMAIL=your_email@example.com
PUBMED_EMAIL=your_email@example.com

# Email for OpenAlex polite pool (optional, uses ENTREZ_EMAIL as fallback)
OPENALEX_EMAIL=your_email@example.com

# Email for Unpaywall OA fulltext lookup (optional, uses ENTREZ_EMAIL as fallback)
UNPAYWALL_EMAIL=your_email@example.com

# Email for Crossref polite pool (optional)
CROSSREF_MAILTO=your_email@example.com

# Semantic Scholar API key (optional — rate-limited without it)
SEMANTIC_SCHOLAR_API_KEY=

# NCBI API key for PubMed (optional — increases rate limit)
NCBI_API_KEY=

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite:///kpi_agent.db
LITERATURE_DB_PATH=literature_cache.db

# ── Embedding / Vector Store ──────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=vector_store/chroma

# ── LLM (Optional — only if using LLM features) ───────────────
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
